 [Unit]
  Description=Color sensor, LEDs, and servo
  After=local-fs.target

  [Service]
  Type=simple
  User=nick
  WorkingDirectory=/home/pi/bo7metrv
  ExecStart=/usr/bin/python3 /home/pi/bo7metrv/run.py
  Environment=PYTHONUNBUFFERED=1
  Restart=on-failure
  RestartSec=5

  [Install]
  WantedBy=multi-user.target


  sudo nano /etc/systemd/system/color-controller.service

  sudo systemctl daemon-reload
  sudo systemctl enable --now color-controller.service